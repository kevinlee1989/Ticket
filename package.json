{
  "name": "ticket-booking-service",
  "version": "1.0.0",
  "description": "Serverless ticket-booking backend on AWS Lambda + DynamoDB with TTL-based optimistic seat locking, OpenSearch-powered search, and S3 presigned uploads",
  "main": "src/handlers/events.js",
  "scripts": {
    "create-search-index": "node scripts/create-search-index.js",
    "deploy": "sam deploy --guided",
    "test": "node --test"
  },
  "keywords": [
    "aws",
    "lambda",
    "dynamodb",
    "opensearch",
    "serverless",
    "ticketing"
  ],
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.675.0",
    "@aws-sdk/client-s3": "^3.675.0",
    "@aws-sdk/lib-dynamodb": "^3.675.0",
    "@aws-sdk/s3-request-presigner": "^3.675.0",
    "@aws-sdk/util-dynamodb": "^3.675.0",
    "@opensearch-project/opensearch": "^2.12.0"
  },
  "devDependencies": {
    "dotenv": "^16.4.7"
  }
}
